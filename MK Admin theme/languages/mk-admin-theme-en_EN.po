#. Plugin Name of the plugin
#: mk-admin-theme.php
msgid "MK Admin Theme"
msgstr "MK Admin Theme"

#. Plugin URI of the plugin
#. Author URI of the plugin
#: mk-admin-theme.php
msgid "https://meksone.com"
msgstr "https://meksone.com"

#. Description of the plugin
#: mk-admin-theme.php
msgid ""
"Custom WordPress admin theme with Poppins font, rounded corners, and a blue/"
"yellow palette. Fully customizable via Settings > Impostazioni tema admin."
msgstr ""
"Custom WordPress admin theme with Poppins font, rounded corners, and a blue/"
"yellow palette. Fully customizable via Settings > Admin Theme Settings."

#. Author of the plugin
#: mk-admin-theme.php
msgid "Manuel Serrenti (meksONE)"
msgstr "Manuel Serrenti (meksONE)"

